{
  "name": "rootmark",
  "version": "0.1.4",
  "description": "Rootmark — Grounded verification for AGENTS.md and AI-agent instructions. Verifies that the Node/npm/pnpm commands written in AGENTS.md-style instruction files match the repository's actual package metadata, without executing anything.",
  "repository": {
    "type": "git",
    "url": "https://github.com/northgardtracker/rootmark"
  },
  "homepage": "https://github.com/northgardtracker/rootmark#readme",
  "bugs": {
    "url": "https://github.com/northgardtracker/rootmark/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "rootmark": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "ci": "pnpm typecheck && pnpm build && pnpm test"
  },
  "keywords": [
    "rootmark",
    "agents-md",
    "AGENTS.md",
    "codex",
    "ai-agents",
    "coding-agents",
    "github-action",
    "developer-tools",
    "agent-instructions",
    "grounded-verification"
  ],
  "author": "Rootmark contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
